<odoo>
    <data>

        <!-- Category for Facebook Integration -->
        <record id="module_category_facebook_integration" model="ir.module.category">
            <field name="name">Facebook Integration</field>
            <field name="description">Facebook Integration Module</field>
        </record>

        <!-- Privilege for Facebook Integration User level -->
        <record id="privilege_facebook_user" model="res.groups.privilege">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_facebook_integration"/>
            <field name="sequence">10</field>
        </record>

        <!-- Facebook Integration User Group -->
        <record id="group_facebook_user" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="privilege_facebook_user"/>
            <field name="comment">Grants full access to Facebook Integration features.</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

    </data>
</odoo>
