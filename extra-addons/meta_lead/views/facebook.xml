<odoo>
    <!-- Read-only Form View -->
    <record id="view_facebook_campaign_form_ro" model="ir.ui.view">
        <field name="name">facebook.campaign.form.readonly</field>
        <field name="model">crm.facebook.campaign</field>
        <field name="arch" type="xml">
            <form string="Facebook Campaign" create="false" edit="false" delete="false">
                <header>
                    <button name="action_fetch_leadforms"
                            type="object"
                            string="Sync Campaigns"
                            class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="fb_form_id" readonly="1"/>
                        <field name="page_id" readonly="1"/>
                        <field name="status" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="view_facebook_campaign_list" model="ir.ui.view">
        <field name="name">facebook.campaign.list</field>
        <field name="model">crm.facebook.campaign</field>
        <field name="arch" type="xml">
            <list string="Facebook Campaigns" create="false" delete="false">
                <field name="name"/>
                <field name="page_id"/>
                <field name="status"/>
                <button name="action_view_leadforms"
                        type="object"
                        string="View Lead Forms"
                        class="btn-secondary"/>
            </list>
        </field>
    </record>

    <!-- Lead Forms Action -->
    <record id="action_facebook_campaign" model="ir.actions.act_window">
        <field name="name">Odoo Facebook Forms</field>
        <field name="res_model">crm.facebook.leadform</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'create': False}</field>
    </record>

    <!-- Odoo Facebook Forms Submenu -->
    <menuitem id="menu_facebook_campaign"
              name="Odoo Facebook Forms"
              parent="menu_facebook_integration_root"
              action="action_facebook_campaign"
              sequence="30"
              groups="meta_lead.group_facebook_user"/>
</odoo>
