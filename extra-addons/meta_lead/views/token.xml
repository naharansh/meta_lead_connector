<odoo>
    <!-- Facebook Instance Form View -->
    <record id="view_facebook_instance_form" model="ir.ui.view">
        <field name="name">facebook.instance.form</field>
        <field name="model">facebook.instance</field>
        <field name="arch" type="xml">
            <form string="Facebook Instance">
                <header>
                    <button name="action_sync_facebook_pages"
                            type="object"
                            string="Sync Facebook Page"
                            class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Facebook Instances"/>
                        </h1>
                    </div>
                    <group string="USER CREDENTIALS">
                        <group>
                            <field name="is_connected" widget="boolean_toggle"/>
                            <field name="access_token"/>
                        </group>
                        <group>
                            <field name="active_scheduler" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <group string="LOGGER CREDENTIALS">
                        <group>
                            <field name="keep_logs"/>
                        </group>
                        <group>
                            <field name="log_scheduler" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Facebook Pages" name="facebook_pages">
                            <field name="page_ids">
                                <list editable="bottom">
                                    <field name="name" string="Page Name"/>
                                    <field name="page_id" string="Page ID"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Facebook Instance List View -->
    <record id="view_facebook_instance_list" model="ir.ui.view">
        <field name="name">facebook.instance.list</field>
        <field name="model">facebook.instance</field>
        <field name="arch" type="xml">
            <list string="Facebook Instances">
                <field name="name"/>
                <field name="is_connected"/>
                <field name="active_scheduler"/>
                <field name="keep_logs"/>
            </list>
        </field>
    </record>

    <!-- Facebook Page Form View (read-only) -->
    <record id="view_facebook_page_form" model="ir.ui.view">
        <field name="name">facebook.page.form</field>
        <field name="model">facebook.page</field>
        <field name="arch" type="xml">
            <form string="Facebook Page" create="false" edit="false" delete="false">
                <header>
                    <button name="action_sync_facebook_forms"
                            type="object"
                            string="Sync Facebook Forms"
                            class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Page Name"/>
                        </h1>
                    </div>
                    <group>
                        <field name="page_id" string="Page ID"/>
                        <field name="instance_id" string="Facebook Instance"/>
                        <field name="access_token" password="True"/>
                        <field name="active_scheduler" widget="boolean_toggle"/>
                    </group>
                    <notebook>
                        <page string="Lead Forms" name="lead_forms">
                            <field name="leadform_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="form_id"/>
                                    
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Facebook Page List View (read-only) -->
    <record id="view_facebook_page_list" model="ir.ui.view">
        <field name="name">facebook.page.list</field>
        <field name="model">facebook.page</field>
        <field name="arch" type="xml">
            <list string="Facebook Pages" create="false" delete="false">
                <field name="name" string="Page Name"/>
                <field name="page_id" string="Page ID"/>
                <field name="instance_id" string="Facebook Instance"/>
                <field name="active_scheduler"/>
            </list>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_facebook_instance" model="ir.actions.act_window">
        <field name="name">Facebook Instances</field>
        <field name="res_model">facebook.instance</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_facebook_page" model="ir.actions.act_window">
        <field name="name">Facebook Pages</field>
        <field name="res_model">facebook.page</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Top-level horizontal App Menu -->
    <menuitem id="menu_facebook_integration_root"
              name="Facebook Integration"
              sequence="10"
              groups="meta_lead.group_facebook_user"/>

    <!-- Submenus -->
    <menuitem id="menu_facebook_instance"
              name="All Facebook Instances"
              parent="menu_facebook_integration_root"
              action="action_facebook_instance"
              sequence="10"
              groups="meta_lead.group_facebook_user"/>

    <menuitem id="menu_facebook_page"
              name="Odoo Facebook Pages"
              parent="menu_facebook_integration_root"
              action="action_facebook_page"
              sequence="20"
              groups="meta_lead.group_facebook_user"/>
</odoo>
